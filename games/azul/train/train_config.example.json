{
  "game_type": "azul",
  "selfplay": {
    "episodes": 50,
    "parallel_games": 8,
    "max_workers": 8,
    "worker_pool": "process",
    "warm_start_episodes": 10000,
    "warm_start_engine": "heuristic",
    "warm_start_simulations": 1,
    "warm_start_train_passes": 2,
    "mcts_schedule": {
      "type": "linear",
      "start_simulations": 500,
      "end_simulations": 500,
      "warmup_episodes": 0,
      "end_episode": 50
