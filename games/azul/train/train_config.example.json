    "policy": {
      "engine": "netmcts",
      "simulations": 500,
      "time_budget_ms": 0,
      "temperature": 0.8,
      "enable_tail_solve": true,
      "search_options": {
        "stop_on_round_transition": true,
        "enable_round_transition_chance": true,
        "chance_expand_cap": 200,
        "max_episode_plies": 100,
        "value_margin_weight": 0.1,
        "value_margin_scale": 15.0
      }
    }
  },
  "trainer": {
    "batch_size": 2048,
    "epochs": 1,
