    "hidden": 512,
    "mlp_layers": 4,
    "updates_per_step": 6,
    "buffer_size": 300000,
    "steps": 10,
    "value_late_weight": 0.6
  },
  "gating": {
    "games": 100,
    "accept_win_rate": 0.55,
    "eval_every_steps": 100,
    "eval_workers": 8,
    "eval_games": 100,
    "history_best_games": 100,
    "history_best_accept_win_rate": 0.55,
    "save_latest_every_steps": 20
  },
  "benchmark_onnx_path": "d:/cursor/Board_game_AI_framework/DinoBoard Intelligence/games/azul/model/model_best.onnx"
